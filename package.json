{
  "name": "planet-of-toys",
  "version": "0.1.0",
  "private": true,
  "description": "Planet of Toys - high-conversion ecommerce platform (monorepo: client + server)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server & npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "test": "npm run test --workspaces --if-present",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client"
  },
  "engines": {
    "node": ">=20"
  }
}
