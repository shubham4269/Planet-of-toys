# Planet of Toys — server environment variables (Req 29).
# Copy to .env and fill in real values. NEVER commit the real .env.
# Bootstrap secrets below are sourced ONLY from the environment (Req 29.1).

# Server
PORT=4000
NODE_ENV=development

# Bootstrap secrets (environment-only)
ENCRYPTION_KEY=
JWT_SECRET=
MONGODB_URI=mongodb://127.0.0.1:27017/planet_of_toys

# Sessions / auth
SESSION_EXPIRATION=2h

# CORS
ALLOWED_ORIGINS=http://localhost:5174

# Uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_MEDIA_TYPES=image/jpeg,image/png,image/webp,video/mp4

# Rate limits (windows in ms, max requests per window) — Req 28.
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_OTP_WINDOW_MS=600000
RATE_LIMIT_OTP_MAX=3
RATE_LIMIT_PAYMENT_WINDOW_MS=900000
RATE_LIMIT_PAYMENT_MAX=20
RATE_LIMIT_ORDER_WINDOW_MS=900000
RATE_LIMIT_ORDER_MAX=20
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
# Failed-login attempts from a source before temporary blocking (Req 25).
LOGIN_BLOCK_THRESHOLD=5

# Integration fallbacks (resolved from System Settings first; Req 29.2)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
# Shared secret for verifying inbound Shiprocket status webhooks (Req 24.1).
# Sent by Shiprocket in the `x-api-key` header. The webhook handler FAILS
# CLOSED: if this is blank, all inbound webhooks are rejected with 401.
SHIPROCKET_WEBHOOK_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_PIXEL_ID=
